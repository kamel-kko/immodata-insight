# ══════════════════════════════════════════════
#  BOOMERANG — Configuration
# ══════════════════════════════════════════════

# ── Boucle Haute (LangGraph) — LLM configurable
# Valeurs possibles : "ollama" | "together"
LLM_PROVIDER=ollama

# Ollama (local — recommandé en Phase 1)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Together.ai (API open source — recommandé en Phase 2)
# TOGETHER_API_KEY=...
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── Forge (Boucle Basse) — via Claude Code CLI subprocess
# IMPORTANT : NE PAS définir ANTHROPIC_API_KEY ici.
# Si ANTHROPIC_API_KEY est présent, Claude Code l'utilise (facturation API).
# Laisser vide = Claude Code utilise ton abonnement Pro/Max (gratuit).
# Assure-toi d'être authentifié : lance "claude" une fois en terminal pour login.

# ── Langfuse Observabilité
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# ── SearXNG
SEARXNG_URL=http://searxng:8080

# ── Base de données
DATABASE_URL=sqlite:////app/data/boomerang.db

# ── Chemins internes
TOOLS_DIR=/app/boomerang_tools
TEMP_TOOLS_DIR=/app/temp_tools
TESTS_DIR=/app/tests
BACKUPS_DIR=/app/backups

# ── Serveur MCP juridique (Légifrance / Open Legi)
# MCP_LEGAL_SERVER_URL=http://localhost:8000

# ── Mode SaaS (desactive la Forge cote client)
SAAS_MODE=false

# ── Authentification Streamlit ──────────────────────────
# L'auth est geree par auth_config.yaml (streamlit-authenticator).
# Supprimez auth_config.yaml pour desactiver l'auth en dev local.
# Comptes par defaut : admin/admin123, architecte/archi2026
# IMPORTANT : changez les mots de passe avant toute mise en production !

# ── Langfuse DB (secrets externalises depuis docker-compose)
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_DB_NAME=langfuse
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_SALT=change-me-in-production

# ── Timeout graph (secondes)
GRAPH_TIMEOUT=120

# ── Cache API (outils geographiques)
CACHE_TTL_JOURS=7
